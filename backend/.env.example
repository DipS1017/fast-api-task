# copy to .env and fill in. never commit the real .env

# signing key for JWTs - generate one with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=60

# sqlite by default, points at a file inside the container/volume
DATABASE_URL=sqlite+aiosqlite:///./app.db

# seed a couple of demo accounts on first boot (dev only)
SEED_DEMO_DATA=true

# how long the mock AI summary call pretends to take, in seconds
SUMMARY_DELAY_SECONDS=2
